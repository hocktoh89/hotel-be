// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  schemas  = ["hotel"]
}

enum UserRole {
  STAFF
  CUSTOMER

  @@schema("hotel")
}

enum RoomType {
  SINGLE
  DOUBLE
  LUXURY

  @@schema("hotel")
}

enum BookingStatus {
  BOOKED
  CANCELLED 
  CHECKED_OUT

  @@schema("hotel")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String
  expires   DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@schema("hotel")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expires   DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@schema("hotel")
}

// Everyone who logs in
model User {
  id                  String               @id @default(cuid())
  email               String               @unique
  username            String               @unique
  password            String
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  passwordResetTokens PasswordResetToken[]
  sessions            Session[]
  role     UserRole @default(CUSTOMER)
  
  // Relations
  bookings      Booking[] @relation("CustomerBookings")
  staffBookings Booking[] @relation("StaffManaged")

  @@map("users")
  @@schema("hotel")
}

// The physical rooms
model Room {
  id       Int    @id @default(autoincrement())
  number   String @unique // e.g., "247"
  category RoomType @default(SINGLE)
  price    Float
  
  bookings Booking[]
  logs     RoomLog[]

  @@map("rooms")
  @@schema("hotel")
}

// The connection between a User and a Room
model Booking {
  id         Int      @id @default(autoincrement())
  
  // The person staying
  customerId String
  customer   User     @relation("CustomerBookings", fields: [customerId], references: [id])

  // The room they are in
  roomId     Int
  room       Room     @relation(fields: [roomId], references: [id])

  // The staff who helped (optional)
  staffId    String?
  staff      User?    @relation("StaffManaged", fields: [staffId], references: [id])

  checkIn    DateTime
  checkOut   DateTime
  status     BookingStatus  @default(BOOKED)
  
  logs       RoomLog[]

  @@map("bookings")
  @@schema("hotel")
}

// To track "who stayed there when damage was reported"
model RoomLog {
  id        Int      @id @default(autoincrement())
  roomId    Int
  room      Room     @relation(fields: [roomId], references: [id])
  bookingId Int?     // Links to the guest who was there at the time
  booking   Booking? @relation(fields: [bookingId], references: [id])
  note      String   // e.g., "Broken window discovered"
  createdAt DateTime @default(now())

  @@map("roomlogs")
  @@schema("hotel")
}
